{
  "openapi": "3.0.3",
  "info": {
    "title": "Teacher Service API",
    "description": "Teacher registration and profiles. Integrates with Student and Exam services via GET /teachers/{id}/summary.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "/", "description": "Same origin (use Try it out in Swagger UI)" }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "service": { "type": "string", "example": "teacher-service" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/teachers": {
      "get": {
        "summary": "List teachers",
        "operationId": "listTeachers",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "teachers": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Teacher" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Register teacher",
        "operationId": "createTeacher",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TeacherCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Teacher" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "409": { "description": "Duplicate" }
        }
      }
    },
    "/teachers/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string", "format": "uuid" }
        }
      ],
      "get": {
        "summary": "Get teacher by UUID",
        "operationId": "getTeacher",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Teacher" }
              }
            }
          },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "summary": "Update teacher",
        "operationId": "updateTeacher",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TeacherUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Teacher" }
              }
            }
          },
          "404": { "description": "Not found" },
          "409": { "description": "Conflict" }
        }
      },
      "delete": {
        "summary": "Delete teacher",
        "operationId": "deleteTeacher",
        "responses": {
          "204": { "description": "No content" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/teachers/{id}/summary": {
      "get": {
        "summary": "Teacher + Student/Exam integration",
        "description": "Uses STUDENT_SERVICE_URL, EXAM_SERVICE_URL, optional DEMO_STUDENT_UUID.",
        "operationId": "getTeacherSummary",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": { "description": "OK" },
          "404": { "description": "Not found" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Teacher": {
        "type": "object",
        "required": ["id", "teacherId", "fullName", "email", "department", "createdAt"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "teacherId": { "type": "string", "example": "T2024001" },
          "fullName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "department": { "type": "string", "example": "Computer Science" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "TeacherCreate": {
        "type": "object",
        "required": ["teacherId", "fullName", "email", "department"],
        "properties": {
          "teacherId": { "type": "string" },
          "fullName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "department": { "type": "string" }
        }
      },
      "TeacherUpdate": {
        "type": "object",
        "properties": {
          "teacherId": { "type": "string" },
          "fullName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "department": { "type": "string" }
        }
      }
    }
  }
}
