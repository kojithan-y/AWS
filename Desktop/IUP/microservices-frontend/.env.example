# Copy to .env and adjust. Vite only exposes env vars prefixed with VITE_.
# Student service default: http://localhost:5000
# Exam service default: http://localhost:5001
# Teacher service default: http://localhost:5002

# VITE_STUDENT_API_URL=http://localhost:5000
# VITE_EXAM_API_URL=http://localhost:5001
# VITE_TEACHER_API_URL=http://localhost:5002
